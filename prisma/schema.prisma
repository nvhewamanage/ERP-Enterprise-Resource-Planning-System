generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
}

model Department {
  id        String      @id @default(cuid())
  name      String
  employees Employee[]
}

model Employee {
  id           String      @id @default(cuid())
  firstName    String
  lastName     String
  email        String      @unique
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
}